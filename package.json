{
  "name": "safemoney",
  "version": "0.1.0",
  "description": "Money-safe TypeScript primitives: currency-safe arithmetic with no floating-point errors, typed ISO 4217 currency codes, rounding policies, FX metadata, formatting and minor-unit conversion.",
  "keywords": [
    "money",
    "currency",
    "decimal",
    "fx",
    "foreign-exchange",
    "iso-4217",
    "rounding",
    "bigint",
    "finance",
    "typescript"
  ],
  "license": "MIT",
  "author": "Ebin Joshy Nambiaparambil",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nambii/safemoney.git"
  },
  "bugs": {
    "url": "https://github.com/nambii/safemoney/issues"
  },
  "homepage": "https://github.com/nambii/safemoney#readme",
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./money": {
      "types": "./dist/esm/money.d.ts",
      "import": "./dist/esm/money.js",
      "require": "./dist/cjs/money.js"
    },
    "./fx": {
      "types": "./dist/esm/fx.d.ts",
      "import": "./dist/esm/fx.js",
      "require": "./dist/cjs/fx.js"
    },
    "./quote": {
      "types": "./dist/esm/quote.d.ts",
      "import": "./dist/esm/quote.js",
      "require": "./dist/cjs/quote.js"
    },
    "./trade": {
      "types": "./dist/esm/trade.d.ts",
      "import": "./dist/esm/trade.js",
      "require": "./dist/cjs/trade.js"
    },
    "./markup": {
      "types": "./dist/esm/markup.d.ts",
      "import": "./dist/esm/markup.js",
      "require": "./dist/cjs/markup.js"
    },
    "./rounding": {
      "types": "./dist/esm/rounding.d.ts",
      "import": "./dist/esm/rounding.js",
      "require": "./dist/cjs/rounding.js"
    },
    "./currencies": {
      "types": "./dist/esm/currencies.d.ts",
      "import": "./dist/esm/currencies.js",
      "require": "./dist/cjs/currencies.js"
    },
    "./decimal": {
      "types": "./dist/esm/decimal.d.ts",
      "import": "./dist/esm/decimal.js",
      "require": "./dist/cjs/decimal.js"
    },
    "./errors": {
      "types": "./dist/esm/errors.d.ts",
      "import": "./dist/esm/errors.js",
      "require": "./dist/cjs/errors.js"
    },
    "./format": {
      "types": "./dist/esm/format.d.ts",
      "import": "./dist/esm/format.js",
      "require": "./dist/cjs/format.js"
    },
    "./portfolio": {
      "types": "./dist/esm/portfolio.d.ts",
      "import": "./dist/esm/portfolio.js",
      "require": "./dist/cjs/portfolio.js"
    },
    "./ratebook": {
      "types": "./dist/esm/ratebook.d.ts",
      "import": "./dist/esm/ratebook.js",
      "require": "./dist/cjs/ratebook.js"
    },
    "./schedule": {
      "types": "./dist/esm/schedule.d.ts",
      "import": "./dist/esm/schedule.js",
      "require": "./dist/cjs/schedule.js"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "clean": "node -e \"const f=require('fs');for(const d of ['dist','dist-test'])f.rmSync(d,{recursive:true,force:true})\"",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build": "npm run clean && npm run build:esm && npm run build:cjs && node scripts/fixup-dist.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build:test": "tsc -p tsconfig.test.json",
    "pretest": "npm run build:test",
    "test": "node --test dist-test/test/*.test.js",
    "coverage": "npm run build:test && c8 node --test dist-test/test/*.test.js",
    "lint": "biome lint ./src ./test ./scripts",
    "format": "biome format --write ./src ./test ./scripts",
    "check": "biome check ./src ./test ./scripts",
    "mutation": "stryker run",
    "examples": "npm run build && node examples/money-basics.mjs && node examples/fx-dealing.mjs",
    "reconcile": "node scripts/reconcile.mjs",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@stryker-mutator/core": "^9.6.1",
    "@types/node": "^20.14.0",
    "c8": "^11.0.0",
    "fast-check": "^4.8.0",
    "typescript": "^5.5.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
